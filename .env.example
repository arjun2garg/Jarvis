# Jarvis — environment variables
# ─────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your keys. Never commit .env.
# ─────────────────────────────────────────────────────────────────

# Todoist API token
# Todoist → Settings → Integrations → Developer → API token
TODOIST_API_KEY=

# Hevy API key  (requires Hevy Pro)
# Hevy → https://hevy.com/settings?developer
HEVY_API_KEY=

# Supabase project URL
# Supabase → Settings → API → Project URL
SUPABASE_URL=

# Supabase service role key  (KEEP SECRET — sync scripts only, never in the browser)
# Supabase → Settings → API → Project API keys → service_role
SUPABASE_SERVICE_KEY=

# Supabase anon public key  (safe to expose — used by the dashboard)
# Supabase → Settings → API → Project API keys → anon public
SUPABASE_ANON_KEY=
